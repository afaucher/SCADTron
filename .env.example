# VITE_GEMINI_API_KEY: Optional Gemini API key for local development.
# If set, the app will use this key automatically.
# If not set, users will be prompted to enter their own key via the BYOK UI.
# The key is never baked into production builds — it's resolved at runtime.
# Get a free key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
